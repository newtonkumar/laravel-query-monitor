{
    "name": "newtonkumar/laravel-query-monitor",
    "description": "Production-grade slow query monitoring for Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "QueryMonitor\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QueryMonitor\\QueryMonitorServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^12.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}